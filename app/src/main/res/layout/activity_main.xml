<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Đầu trang: ảnh đại diện + tên. Bấm vào mở màn hình Cá nhân. -->
        <LinearLayout
            android:id="@+id/headerCaNhan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp">

                <ImageView
                    android:id="@+id/imgAvatarHome"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/anh_dai_dien"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_avatar_mac_dinh" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_title"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTenNguoiDung"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bộ 600 câu — Cục CSGT (áp dụng từ 01/6/2025)"
            android:textSize="13sp"
            android:alpha="0.7"
            android:paddingBottom="12dp" />

        <!-- Đếm ngược ngày thi (dùng DatePicker) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chưa đặt ngày thi dự kiến"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDatNgayThi"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/dat_ngay_thi" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOnTap"
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_columnWeight="1"
                android:backgroundTint="@color/tile_1"
                android:text="@string/menu_on_tap"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDiemLiet"
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_columnWeight="1"
                android:backgroundTint="@color/tile_3"
                android:text="@string/menu_diem_liet"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThi"
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_columnWeight="1"
                android:backgroundTint="@color/tile_2"
                android:text="@string/menu_thi"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBienBao"
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_columnWeight="1"
                android:backgroundTint="@color/tile_6"
                android:text="@string/menu_bien_bao"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThongKe"
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_columnWeight="1"
                android:backgroundTint="@color/tile_5"
                android:text="@string/menu_thong_ke"
                app:cornerRadius="14dp" />
        </GridLayout>
    </LinearLayout>
</ScrollView>
